---
---

<footer class="p-8">
  <section class="flex flex-col mb-6 2xl:mb-0">
    <img
      src="/sungiant-logo.png"
      alt="Sun Giant Logo"
      class="sm:max-w-xs 2xl:self-end"
    />
  </section>
  <section class="2xl:flex justify-between items-center">
    <!-- ADDRESSES -->
    <div>
      <div class="lg:grid lg:grid-cols-3 lg:space-x-8 text-xl">
        <div class="mb-8 lg:mb-0">
          <p class="text-pink-600 font-semibold">
            <i class="fa-solid fa-location-dot"></i> Phoenix
          </p>
          <address>
            <p>Tempe, AZ 85282</p>
            <p>2305 W. Huntington Drive</p>
          </address>
          <p class="text-pink-600 font-semibold">
            <a href="tel:602-454-7000" class="hover:underline"
              >LOCAL: 602-454-7000</a
            >
          </p>
        </div>
        <div class="mb-8 lg:mb-0">
          <p class="text-pink-600 font-semibold">
            <i class="fa-solid fa-location-dot"></i> Tucson
          </p>
          <address>
            <p>Tucson, AZ 85704</p>
            <p>7090 N Oracle Road #178</p>
          </address>
          <p class="text-pink-600 font-semibold">
            <a href="tel:520-770-9902" class="hover:underline"
              >LOCAL: 520-770-9902</a
            >
          </p>
        </div>
        <div class="mb-8 lg:mb-0">
          <p class="text-pink-600 font-semibold">
            <i class="fa-solid fa-location-dot"></i> Las Vegas
          </p>
          <address>
            <p>Las Vegas, NV 89118</p>
            <p>5424 S. Cameron St. #102</p>
          </address>
          <p class="text-pink-600 font-semibold">
            <a href="tel:702-435-4820" class="hover:underline"
              >LOCAL: 702-435-4820</a
            >
          </p>
        </div>
      </div>
    </div>
    <!-- LOGOS ROW -->
    <div>
      <!-- DESKTOP VER -->
      <img
        src="/logos-row.png"
        alt="row of logos - Made in USA, Better Business Bureau, Use Solar, Pet Friendly, 5 Star Company, Best Product Guarantee, US Flag"
        class="hidden sm:block lg:mt-6 2xl:mt-0"
      />
      <!-- MOBILE VER -->
      <img
      src="/logos-row-mobile.png"
      alt="row of logos - Made in USA, Better Business Bureau, Use Solar, Pet Friendly, 5 Star Company, Best Product Guarantee, US Flag"
      class="sm:hidden"
    />
    </div>
  </section>
  <!-- COPYRIGHT -->
  <section class="2xl:text-right text-xl mt-6 lg:mt-0">
    <div id="copyright">
      <!-- COPYRIGHT GENERATED IN JS FILE -->
    </div>
  </section>
</footer>
<style></style>

<script is:inline>
  // FOR COPYRIGHT STATEMENT STAYING WITH CURRENT YEAR

  const copyrightStatement = `&copy; ${new Date().getFullYear()} Green Energy Inc.`;

  document.getElementById("copyright").innerHTML = copyrightStatement;
</script>
