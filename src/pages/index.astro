---
import Layout from "../layouts/Layout.astro";
import ServiceForm from "../components/ServiceForm.astro";
---

<Layout
  title="Fafco Solar Pool Heating Service"
  description="We provide service to all Fafco Solar Pool Heating customers in Arizon and Nevada"
  keywords="fafco, fafco solar pool heating, solar pool heating, fafco pool solar, pool solar, nevada solar pool heating, arizona solar pool heating, fafco home pool solar, fafco sph system, fafco pool heating system"
  canonicalURL="https://fafco.net/"
  robots="index, follow"
>
  <main class="p-8">
    <section>
      <div class="flex flex-col flex-col-reverse 2xl:grid 2xl:grid-cols-2">
        <div>
          <!-- JOTFORM -->
          <ServiceForm />
        </div>
        <div>
          <div>
            <div class="flex items-center relative max-w-4xl mx-auto">
              <img
                src="/pool-illustration.png"
                alt="pool illustration"
                class="z-0 max-w-[80%] lg:max-w-2xl"
              />
              <img
                src="/technician-with-big-wrench.png"
                alt="illustration of technician with big wrench"
                class="z-10 absolute right-0 lg:right-10 max-w-[40%] lg:max-w-xs"
              />
            </div>
          </div>
          <br />
          <div class="max-w-4xl mx-auto">
            <div class="max-w-3xl">
              <h1 class="text-3xl lg:text-5xl font-black text-sky-500">
                Service for Fafco Solar Pool Heating - AZ & NV
              </h1>
              <br />
              <p class="text-xl lg:text-3xl">
                We provide service to Fafco Solar Pool Heating customers in
                Arizona and Nevada.
              </p>
              <br />
              <p class="text-xl lg:text-3xl">
                Do you need service on your Fafco Solar Pool Heating system? Fill
                out the contact form on this page, and we will reach out to you.
              </p>
            </div>
          </div>
          <br />
          <img
            src="/badges-row.png"
            alt="badges row - 40,000 Installations in The Southwest, Trusted and Referred for Over 36 Years, 36 Years Anniversary"
            class="w-full lg:max-w-3xl mx-auto 2xl:mx-0"
          />
        </div>
      </div>
    </section>
  </main>
</Layout>

